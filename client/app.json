{
  "expo": {
    "name": "Quorax - Finance Tracker",
    "slug": "client",
    "version": "1.0.4",
    "orientation": "portrait",
    "scheme": "spendwise",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/SpendWise_Logo-removebg-preview.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sherwincari.spendwise"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Quorax needs access to your photos to attach receipts to transactions.",
          "cameraPermission": "Quorax needs access to your camera to photograph receipts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0D9488"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2a5588a2-9126-48d2-9a7d-a6f488746239"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2a5588a2-9126-48d2-9a7d-a6f488746239"
    }
  }
}
